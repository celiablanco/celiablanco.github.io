---
<BaseLayout title="Publicaciones — Dra. Celia Blanco" description="Publicaciones revisadas por pares y preprints de la Dra. Celia Blanco.">
  <section class="page-hero">
    <div class="container">
      <h1>Publicaciones</h1>
      <p class="lede">
        Artículos revisados por pares, preprints y capítulos de libro. Para
        recuentos de citas y el registro actualizado, visita
        <a href="https://scholar.google.com/citations?user=nzOjUiUAAAAJ&hl=en" target="_blank" rel="noopener">Google Scholar</a>.
      </p>
    </div>
  </section>

  <section class="section pubs">
    <div class="container">
      <!-- En curso -->
      <div class="year-block reveal">
        <div class="year-marker">
          <span class="year-num">En&nbsp;curso</span>
          <span class="year-rule"></span>
        </div>
        <ul class="pub-list">
          {inProgress.map((p) => (
            <li class="pub">
              <p class="pub-title">{p.title}</p>
              <p class="pub-meta">
                <span class="authors">{p.authors}</span>
                <span class="sep">·</span>
                <span class="venue">{p.venue}</span>
              </p>
            </li>
          ))}
        </ul>
      </div>

      {groups.map((g) => (
        <div class="year-block reveal" id={`y-${g.year}`}>
          <div class="year-marker">
            <span class="year-num">{g.year}</span>
            <span class="year-rule"></span>
          </div>
          <ul class="pub-list">
            {g.pubs.map((p) => (
              <li class="pub">
                <p class="pub-title">
                  {p.href ? <a href={p.href} target="_blank" rel="noopener">{p.title}</a> : p.title}
                </p>
                <p class="pub-meta">
                  <span class="authors" set:html={p.authors.replace(/(C\.\s?Blanco)/g, '<mark>$1</mark>')} />
                  <span class="sep">·</span>
                  <span class="venue">{p.venue}</span>
                </p>
                {p.extras && (
                  <p class="pub-extras">
                    {p.extras.map((e, i) => (
                      <>
                        {i > 0 && <span class="dot"> · </span>}
                        <a href={e.href} target="_blank" rel="noopener">{e.label}</a>
                      </>
                    ))}
                  </p>
                )}
              </li>
            ))}
          </ul>
        </div>
      ))}

      <div class="cta-block reveal">
        <p>
          No dudes en escribirme si hay algo de lo que te gustaría hablar.
          Siempre estoy abierta a nuevas ideas y colaboraciones.
        </p>
        <a class="btn" href="/es/contact"><span>Contacta conmigo</span></a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding: var(--space-6) 0 var(--space-4);
  }

  .page-hero h1 {
    font-weight: 400;
    margin: 0 0 var(--space-3);
    font-size: clamp(2rem, 4vw, 3rem);
  }

  .page-hero .lede {
    max-width: 640px;
    margin: 0;
    font-size: 1.05rem;
    color: var(--color-text-muted);
  }

  .pubs {
    padding-top: var(--space-4);
  }

  .year-block {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: var(--space-5);
    padding: var(--space-4) 0;
    align-items: start;
  }

  .year-marker {
    position: sticky;
    top: 110px;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .year-num {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 500;
    line-height: 1;
    color: var(--color-text-muted);
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .year-rule {
    width: 60px;
    height: 1px;
    background: var(--color-border);
  }

  .pub-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .pub {
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .pub:last-child {
    border-bottom: none;
  }

  .pub-title {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.45;
    color: var(--color-text);
    margin: 0 0 0.4rem;
  }

  .pub-title a {
    color: var(--color-text);
    background-image: linear-gradient(var(--color-gold), var(--color-gold));
    background-size: 0% 1px;
    background-position: 0 100%;
    background-repeat: no-repeat;
    transition: background-size 0.4s var(--ease-out), color 0.2s ease;
  }

  .pub-title a:hover,
  .pub-title a:focus-visible {
    background-size: 100% 1px;
    color: var(--color-gold-bright);
  }

  .pub-meta {
    font-size: 0.92rem;
    color: var(--color-text-subtle);
    margin: 0;
    line-height: 1.6;
  }

  .pub-meta .authors {
    color: var(--color-text-muted);
  }

  .pub-meta :global(mark) {
    background: transparent;
    color: var(--color-text);
    font-weight: 500;
  }

  .pub-meta .sep {
    margin: 0 0.6em;
    color: var(--color-text-subtle);
  }

  .pub-meta .venue {
    font-style: italic;
  }

  .pub-extras {
    margin: 0.4rem 0 0;
    font-size: 0.82rem;
    color: var(--color-text-subtle);
  }

  .pub-extras a {
    color: var(--color-cyan);
    background-image: none;
  }

  .pub-extras a:hover {
    color: var(--color-gold-bright);
  }

  .pub-extras .dot {
    color: var(--color-text-subtle);
  }

  .cta-block {
    text-align: center;
    padding: var(--space-5) 0 var(--space-3);
  }

  .cta-block h3 {
    font-size: clamp(1.4rem, 2.4vw, 2rem);
    font-weight: 300;
    color: var(--color-text);
    margin-bottom: var(--space-2);
  }

  .cta-block p {
    margin-bottom: var(--space-4);
    max-width: 540px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-block {
    margin-top: var(--space-5);
    padding: var(--space-5) var(--space-4);
    text-align: center;
    border-top: 1px solid var(--color-border-subtle);
  }

  .cta-block p {
    max-width: 540px;
    margin: 0 auto var(--space-3);
    color: var(--color-text-muted);
  }

  @media (max-width: 700px) {
    .year-block {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }

    .year-marker {
      position: static;
      flex-direction: row;
      align-items: center;
    }

    .year-rule {
      flex: 1;
    }

    .pub-title {
      font-size: 1.05rem;
    }
  }
</style>
