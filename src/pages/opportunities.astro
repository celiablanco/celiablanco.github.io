---
import BaseLayout from '../layouts/BaseLayout.astro';

type Opportunity = {
  title: string;
  href?: string;
  audience: ('undergrad' | 'phd' | 'postdoc')[];
  description: string;
  deadline?: string;
};

const categories: { id: string; label: string; sublabel: string; items: Opportunity[] }[] = [
  {
    id: 'offered',
    label: 'Paid Positions I Offer',
    sublabel: 'When I have funding or capacity, I recruit through these programs. Check the CSIC job board or contact me to express interest.',
    items: [
      {
        title: 'FPI — Formación de Personal Investigador',
        href: 'https://www.ciencia.gob.es',
        audience: ['phd'],
        description:
          'Predoctoral contracts tied to specific research projects funded by the Spanish Ministry of Science. When I have an FPI-eligible grant, I advertise the position — the contract is with my group at CAB. Keep an eye on the CSIC job board or contact me directly.',
        deadline: 'Advertised when a project has an open FPI slot',
      },
      {
        title: 'CSIC JAE-Predoc',
        href: 'https://www.csic.es',
        audience: ['phd'],
        description:
          'Competitive predoctoral fellowships from the Spanish National Research Council (CSIC) to carry out a PhD thesis at CSIC institutes. I can participate as thesis supervisor at CAB. Search "JAE Predoc" on the CSIC website for the current call.',
        deadline: 'Typically opens in spring',
      },
      {
        title: 'CSIC JAE-Intro',
        href: 'https://www.csic.es',
        audience: ['undergrad'],
        description:
          'Summer research internships for undergraduate students at CSIC institutes. I can host students at CAB for a 2–3 month project in astrobiology, prebiotic chemistry, or computational biology. Contact me before the call opens. Search "JAE Intro" on the CSIC website for the current call.',
        deadline: 'Typically opens in spring',
      },
    ],
  },
  {
    id: 'unpaid',
    label: 'Unpaid Research Experience',
    sublabel: 'No contract or funding required — good for anyone looking to gain research experience. I am a BMSIS mentor and may have projects available in both programs.',
    items: [
      {
        title: 'Bachelor\'s & Master\'s Thesis Supervision (TFG / TFM)',
        audience: ['undergrad'],
        description:
          'If you are considering a career in astrobiology or origins of life research and are looking for a supervisor for your final degree project (TFG or TFM), I am always open to discussing it. Reach out with a brief description of your background and interests.',
      },
      {
        title: 'BMSIS Young Scientist Program',
        href: 'https://bmsis.org/ysp/',
        audience: ['undergrad'],
        description:
          'Blue Marble Space Institute of Science mentored research program for undergraduate students and recent undergrads not yet in graduate school. Fully remote and unpaid; participants work on astrobiology and space science projects with BMSIS researchers. I am a BMSIS mentor and may have projects available.',
        deadline: 'Typically spring (June–August)',
      },
      {
        title: 'BMSIS Visiting Scholars Program',
        href: 'https://bmsis.org/visitingscholars/',
        audience: ['phd', 'postdoc'],
        description:
          'One-year unpaid research appointments at BMSIS, supervised by a Research Scientist. Open to graduate students, degree holders, and BMSIS YSP alumni. A good complement to a primary affiliation — fully remote and renewable. I am a BMSIS mentor and can supervise projects in my research areas.',
        deadline: 'Rolling (contact a BMSIS Research Scientist)',
      },
    ],
  },
  {
    id: 'phd',
    label: 'PhD Fellowships',
    sublabel: 'You apply independently and, if successful, choose your host group. I can serve as host supervisor at CAB — contact me before you submit.',
    items: [
      {
        title: 'Comunidad de Madrid — Predoctoral Research Personnel Contracts',
        href: 'https://sede.comunidad.madrid/ayudas-becas-subvenciones/personal-investigador-predoctoral',
        audience: ['phd'],
        description:
          'Regional predoctoral funding from the Comunidad de Madrid for research centers in the Madrid region. CAB is an eligible host institution. Applied for jointly by the student and the supervisor — no existing project funding required from my side. Contact me if you want to apply together.',
        deadline: 'Typically announced in autumn',
      },
      {
        title: 'FPU — Formación de Profesorado Universitario',
        href: 'https://www.ciencia.gob.es',
        audience: ['phd'],
        description:
          'Spanish Ministry of Science predoctoral fellowships for students enrolled in or planning a PhD at a Spanish university or research center. Provides a 4-year stipend. Applicants apply independently and then formalize a host agreement with a supervisor.',
        deadline: 'Typically opens in autumn',
      },
      {
        title: '"la Caixa" Foundation INPhINIT Doctoral Fellowships',
        href: 'https://fundacionlacaixa.org/en/inphinit-doctoral-fellowships-incoming',
        audience: ['phd'],
        description:
          'Highly competitive fellowships for doctoral studies at centers of excellence in Spain and Portugal. The Incoming track is open to any nationality; the Retaining track targets those already in Spain/Portugal. CAB is eligible as a María de Maeztu–accredited center.',
        deadline: 'Typically opens in autumn',
      },
      {
        title: 'Fundación Ramón Areces — Doctoral Fellowships in Life & Matter Sciences',
        href: 'https://www.fundacionareces.es/fundacionareces/en/call-of-grants/scholarships-and-grants/',
        audience: ['phd'],
        description:
          'Annual doctoral fellowships from the Ramón Areces Foundation for students pursuing a PhD at Spanish universities or research centers in the life and matter sciences (biology, chemistry, physics, biomedicine). Competitive and well-funded.',
        deadline: 'Typically opens in autumn',
      },
    ],
  },
  {
    id: 'postdoc',
    label: 'Postdoctoral Fellowships',
    sublabel: 'You apply with a host researcher. I can act as host PI at CAB — get in touch early so we can develop the project together.',
    items: [
      {
        title: 'Juan de la Cierva — Formación & Incorporación',
        href: 'https://www.ciencia.gob.es',
        audience: ['postdoc'],
        description:
          '"Formación" supports 2-year training contracts for early postdocs (up to 2 years post-PhD); "Incorporación" supports 3-year contracts for more experienced researchers (2–5 years post-PhD). Applicants apply with a host institution — I can host at CAB.',
        deadline: 'Typically opens in autumn',
      },
      {
        title: 'Marie Skłodowska-Curie Postdoctoral Fellowships (MSCA-PF)',
        href: 'https://marie-sklodowska-curie-actions.ec.europa.eu/actions/postdoctoral-fellowships',
        audience: ['postdoc'],
        description:
          'European fellowships for experienced researchers to carry out 1–2 year projects at a European host institution. Open to any nationality. I am happy to support strong applicants with the proposal — contact me well before the deadline.',
        deadline: 'Typically September',
      },
      {
        title: '"la Caixa" Junior Leader Postdoctoral Fellowships',
        href: 'https://fundacionlacaixa.org/en/postdoctoral-fellowships-junior-leader-incoming',
        audience: ['postdoc'],
        description:
          'Prestigious 3-year postdoctoral fellowships for researchers at accredited Spanish or Portuguese institutions. The Incoming track is open to any nationality; the Retaining track targets those already based in Spain/Portugal. CAB is eligible as a María de Maeztu center.',
        deadline: 'Typically opens in spring',
      },
    ],
  },
];

const audienceLabel: Record<string, string> = {
  undergrad: 'Undergrad',
  phd: 'PhD',
  postdoc: 'Postdoc',
};
---

<BaseLayout
  title="Opportunities — Dr. Celia Blanco"
  description="Funding, fellowship, and research opportunities for students and early-career researchers interested in joining the group or working in astrobiology and origins of life."
>
  <section class="page-hero">
    <div class="container">
      <h1>Opportunities</h1>
      <p class="lede">
        Fellowships and calls for joining the group. Organized by who
        advertises the position — me, or you. Deadlines change annually; always
        verify on the official website.
      </p>
    </div>
  </section>

  <section class="section opp-section">
    <div class="container">

      <!-- Join the group callout -->
      <div class="join-block reveal">
        <div class="join-inner">
          <p class="join-eyebrow">Interested in joining the group?</p>
          <p class="join-body">
            I welcome inquiries from motivated students and researchers at all stages.
            Whether you are looking for a PhD, postdoc, or short research visit, feel
            free to reach out — and do mention any specific fellowship you plan to
            apply for.
          </p>
          <a class="btn btn-ghost" href="/contact">Get in touch</a>
        </div>
      </div>

      <!-- Filter bar -->
      <div class="filter-bar reveal">
        <span class="filter-label">Filter by:</span>
        <div class="filter-btns" role="group" aria-label="Filter opportunities by audience">
          <button class="filter-btn active" data-filter="all">All</button>
          <button class="filter-btn" data-filter="undergrad">Undergrad</button>
          <button class="filter-btn" data-filter="phd">PhD</button>
          <button class="filter-btn" data-filter="postdoc">Postdoc</button>
        </div>
      </div>

      <!-- Opportunity categories -->
      {categories.map((cat) => (
        <div class="cat-block reveal" id={cat.id} data-category={cat.id}>
          <div class="cat-marker">
            <span class="cat-label">{cat.label}</span>
            <span class="cat-rule"></span>
            <p class="cat-sublabel">{cat.sublabel}</p>
          </div>
          <ul class="opp-list">
            {cat.items.map((item) => (
              <li
                class="opp-item"
                data-audience={item.audience.join(' ')}
              >
                <div class="opp-header">
                  <p class="opp-title">
                    {item.href
                      ? <a href={item.href} target="_blank" rel="noopener">{item.title}</a>
                      : item.title}
                  </p>
                  <div class="opp-tags">
                    {item.audience.map((a) => (
                      <span class:list={['tag', `tag-${a}`]}>{audienceLabel[a]}</span>
                    ))}
                  </div>
                </div>
                <p class="opp-desc">{item.description}</p>
                {item.deadline && (
                  <p class="opp-deadline">
                    <span class="deadline-icon" aria-hidden="true">⟳</span>
                    {item.deadline}
                  </p>
                )}
              </li>
            ))}
          </ul>
        </div>
      ))}

      <div class="cta-block reveal">
        <p>
          Know of a relevant opportunity that should be listed here? Send me a note.
        </p>
        <a class="btn" href="/contact"><span>Contact me</span></a>
      </div>

    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding: var(--space-6) 0 var(--space-4);
  }

  .page-hero h1 {
    font-weight: 400;
    margin: 0 0 var(--space-3);
    font-size: clamp(2rem, 4vw, 3rem);
  }

  .page-hero .lede {
    max-width: 660px;
    margin: 0;
    font-size: 1.05rem;
    color: var(--color-text-muted);
  }

  .opp-section {
    padding-top: var(--space-4);
  }

  /* ── Join the group ── */
  .join-block {
    margin-bottom: var(--space-5);
    padding: var(--space-4) var(--space-5);
    background: linear-gradient(135deg, rgba(212, 175, 111, 0.06), rgba(125, 211, 252, 0.04));
    border: 1px solid rgba(212, 175, 111, 0.2);
    border-radius: var(--radius-lg);
  }

  .join-eyebrow {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-gold);
    margin: 0 0 var(--space-2);
  }

  .join-body {
    max-width: 620px;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-3);
    font-size: 0.97rem;
  }

  /* ── Filter bar ── */
  .filter-bar {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .filter-label {
    font-size: 0.82rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-text-subtle);
  }

  .filter-btns {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .filter-btn {
    padding: 0.35rem 0.9rem;
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 500;
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: background 0.2s var(--ease), border-color 0.2s var(--ease), color 0.2s var(--ease);
  }

  .filter-btn:hover {
    background: rgba(255, 255, 255, 0.05);
    color: var(--color-text);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .filter-btn.active {
    background: var(--color-gold-soft);
    border-color: var(--color-gold);
    color: var(--color-gold-bright);
  }

  /* ── Category blocks ── */
  .cat-block {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: var(--space-5);
    padding: var(--space-4) 0;
    align-items: start;
    border-top: 1px solid var(--color-border-subtle);
  }

  .cat-marker {
    position: sticky;
    top: 110px;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .cat-label {
    font-family: var(--font-sans);
    font-size: 0.88rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-text);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .cat-rule {
    width: 40px;
    height: 1px;
    background: var(--color-border);
  }

  .cat-sublabel {
    font-size: 0.82rem;
    color: var(--color-text-subtle);
    line-height: 1.55;
    margin: 0;
    font-style: italic;
  }

  /* ── Opportunity list ── */
  .opp-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .opp-item {
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--color-border-subtle);
    transition: opacity 0.25s var(--ease);
  }

  .opp-item:last-child {
    border-bottom: none;
  }

  .opp-item.hidden {
    display: none;
  }

  .opp-header {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.6rem var(--space-2);
    margin-bottom: 0.5rem;
  }

  .opp-title {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.45;
    color: var(--color-text);
    margin: 0;
  }

  .opp-title a {
    color: var(--color-text);
    background-image: linear-gradient(var(--color-gold), var(--color-gold));
    background-size: 0% 1px;
    background-position: 0 100%;
    background-repeat: no-repeat;
    text-decoration: none;
    transition: background-size 0.4s var(--ease-out), color 0.2s ease;
  }

  .opp-title a:hover,
  .opp-title a:focus-visible {
    background-size: 100% 1px;
    color: var(--color-gold-bright);
  }

  .opp-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    flex-shrink: 0;
  }

  .tag {
    display: inline-block;
    padding: 0.15rem 0.55rem;
    font-size: 0.72rem;
    font-weight: 500;
    border-radius: 999px;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  .tag-undergrad {
    background: rgba(125, 211, 252, 0.12);
    color: var(--color-cyan);
    border: 1px solid rgba(125, 211, 252, 0.25);
  }

  .tag-phd {
    background: var(--color-gold-soft);
    color: var(--color-gold-bright);
    border: 1px solid rgba(212, 175, 111, 0.3);
  }

  .tag-postdoc {
    background: rgba(167, 139, 250, 0.12);
    color: #c4b5fd;
    border: 1px solid rgba(167, 139, 250, 0.25);
  }

  .opp-desc {
    font-size: 0.93rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0 0 0.4rem;
  }

  .opp-deadline {
    font-size: 0.82rem;
    color: var(--color-text-subtle);
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .deadline-icon {
    font-size: 0.9em;
    color: var(--color-gold);
  }

  /* ── CTA ── */
  .cta-block {
    margin-top: var(--space-6);
    padding: var(--space-5) var(--space-4);
    text-align: center;
    border-top: 1px solid var(--color-border-subtle);
  }

  .cta-block p {
    max-width: 480px;
    margin: 0 auto var(--space-3);
    color: var(--color-text-muted);
  }

  /* ── Responsive ── */
  @media (max-width: 720px) {
    .cat-block {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }

    .cat-marker {
      position: static;
    }

    .join-block {
      padding: var(--space-3);
    }
  }

  @media (max-width: 480px) {
    .opp-header {
      flex-direction: column;
      gap: 0.5rem;
    }
  }
</style>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const items = document.querySelectorAll<HTMLLIElement>('.opp-item');
  const catBlocks = document.querySelectorAll<HTMLDivElement>('.cat-block');

  btns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter ?? 'all';

      btns.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');

      items.forEach((item) => {
        if (filter === 'all') {
          item.classList.remove('hidden');
        } else {
          const audience = item.dataset.audience?.split(' ') ?? [];
          item.classList.toggle('hidden', !audience.includes(filter));
        }
      });

      catBlocks.forEach((block) => {
        const visible = block.querySelectorAll('.opp-item:not(.hidden)');
        block.style.display = visible.length === 0 ? 'none' : '';
      });
    });
  });
</script>
