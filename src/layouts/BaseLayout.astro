---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Starfield from '../components/Starfield.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Dr. Celia Blanco — Theoretical Physicist & Astrobiologist',
  description = 'Theoretical physicist and astrobiologist exploring the origins and evolution of life in the universe. Ramón y Cajal Fellow at the Centro de Astrobiología (CAB, CSIC-INTA).',
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/img/favicon.png" type="image/png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#060818" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..600;1,9..144,300..500&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Starfield />
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <script>
      // Reveal-on-scroll
      const els = document.querySelectorAll<HTMLElement>('.reveal');
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            }
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.05 }
        );
        els.forEach((el) => io.observe(el));
      } else {
        els.forEach((el) => el.classList.add('is-visible'));
      }
    </script>

    <style>
      .skip-link {
        position: absolute;
        top: -40px;
        left: 0;
        padding: 0.5rem 1rem;
        background: var(--color-gold);
        color: var(--color-bg);
        font-size: 0.85rem;
        font-weight: 500;
        z-index: 100;
        background-image: none;
      }
      .skip-link:focus {
        top: 0;
      }
    </style>
  </body>
</html>
