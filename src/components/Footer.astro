---
const profiles = [
  {
    name: 'Google Scholar',
    href: 'https://scholar.google.com/citations?user=nzOjUiUAAAAJ&hl=en',
    icon: 'scholar',
  },
  {
    name: 'ORCID',
    href: 'https://orcid.org/0000-0003-1536-1493',
    icon: 'orcid',
  },
  {
    name: 'ResearchGate',
    href: 'https://www.researchgate.net/profile/Celia-Blanco',
    icon: 'researchgate',
  },
  {
    name: 'LinkedIn',
    href: 'https://www.linkedin.com/in/celiablanco/',
    icon: 'linkedin',
  },
];

const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container footer-inner">
    <ul class="profiles">
      {profiles.map(({ name, href, icon }) => (
        <li>
          <a href={href} target="_blank" rel="noopener noreferrer" aria-label={name}>
            <span class="icon" data-icon={icon}>
              {icon === 'scholar' && (
                <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M5.242 13.769L0.5 9.5 12 1l11.5 8.5-4.742 4.269C17.86 11.027 15.062 9 12 9c-3.062 0-5.86 2.027-6.758 4.769zM12 10a7 7 0 1 0 0 14 7 7 0 0 0 0-14z"/></svg>
              )}
              {icon === 'orcid' && (
                <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zM7.369 4.378c.525 0 .947.431.947.947 0 .525-.422.947-.947.947-.525 0-.946-.422-.946-.947 0-.525.421-.947.946-.947zm-.722 3.038h1.444v10.041H6.647V7.416zm3.562 0h3.9c3.712 0 5.344 2.653 5.344 5.025 0 2.578-2.016 5.025-5.325 5.025h-3.919V7.416zm1.444 1.303v7.444h2.297c3.272 0 4.022-2.484 4.022-3.722 0-2.016-1.284-3.722-4.097-3.722h-2.222z"/></svg>
              )}
              {icon === 'researchgate' && (
                <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M19.586 0H4.414A4.414 4.414 0 0 0 0 4.414v15.172A4.414 4.414 0 0 0 4.414 24h15.172A4.414 4.414 0 0 0 24 19.586V4.414A4.414 4.414 0 0 0 19.586 0zM8.5 17h-1.7v-7.7c0-.45.066-.84.197-1.166a2.187 2.187 0 0 1 .56-.815c.243-.21.534-.366.873-.467.34-.1.715-.151 1.127-.151.342 0 .69.043 1.045.13.355.087.679.227.97.42a2.4 2.4 0 0 1 .714.74c.184.302.276.673.276 1.114h-1.728c0-.176-.038-.323-.114-.44a.945.945 0 0 0-.297-.282 1.255 1.255 0 0 0-.42-.151 2.642 2.642 0 0 0-.456-.041c-.245 0-.453.034-.622.103a.948.948 0 0 0-.4.295.91.91 0 0 0-.197.452 3.81 3.81 0 0 0-.05.59V17zm9.16-1.79c-.276.43-.66.792-1.151 1.083-.49.291-1.077.494-1.762.61a4.94 4.94 0 0 1-.823.07h-.116a4.55 4.55 0 0 1-1.844-.395 5.1 5.1 0 0 1-1.553-1.066 5.073 5.073 0 0 1-1.075-1.55 4.61 4.61 0 0 1-.4-1.892c0-.69.143-1.323.43-1.9a4.93 4.93 0 0 1 1.16-1.5 5.486 5.486 0 0 1 1.685-.984c.638-.235 1.302-.353 1.992-.353.69 0 1.354.117 1.992.353.638.235 1.2.563 1.685.984.485.42.872.92 1.16 1.499.288.578.43 1.21.43 1.9 0 .415-.057.815-.17 1.2a4.575 4.575 0 0 1-.484 1.066 4.85 4.85 0 0 1-.156-.124zm-2.85-3.94a3.183 3.183 0 0 0-.652-1.018 3.06 3.06 0 0 0-.989-.677 3.135 3.135 0 0 0-1.252-.246 3.18 3.18 0 0 0-1.247.246 3.06 3.06 0 0 0-.99.677 3.183 3.183 0 0 0-.65 1.018c-.158.391-.237.81-.237 1.255 0 .447.079.866.237 1.257.158.39.376.728.65 1.014.275.286.605.512.99.677.385.165.8.247 1.247.247.45 0 .867-.082 1.252-.247a3.06 3.06 0 0 0 .989-.677c.275-.286.492-.624.65-1.014.16-.391.238-.81.238-1.257 0-.444-.079-.864-.237-1.255z"/></svg>
              )}
              {icon === 'linkedin' && (
                <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
              )}
            </span>
            <span class="profile-label">{name}</span>
          </a>
        </li>
      ))}
    </ul>
    <p class="footer-meta">
      &copy; {year} Celia Blanco · Centro de Astrobiología (CAB, CSIC-INTA)
    </p>
  </div>
</footer>

<style>
  .site-footer {
    padding: var(--space-5) 0 var(--space-4);
    margin-top: var(--space-7);
    border-top: 1px solid var(--color-border-subtle);
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  .profiles {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-3) var(--space-4);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .profiles a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s var(--ease);
  }

  .profiles a:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  .icon {
    display: inline-flex;
    color: var(--color-text-muted);
    transition: color 0.2s var(--ease);
  }

  .profiles a:hover .icon {
    color: var(--color-text);
  }

  .profile-label {
    font-size: 0.88rem;
  }

  .footer-meta {
    color: var(--color-text-subtle);
    font-size: 0.82rem;
    margin: 0;
  }

  @media (max-width: 600px) {
    .profiles {
      gap: var(--space-2) var(--space-3);
    }
  }
</style>
