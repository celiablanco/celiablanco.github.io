---
// Background — a calm deep-navy gradient. No stars; the previous tiled
// star-dots were too sparse and read as glitch rather than cosmos.
---
<div class="bg" aria-hidden="true"></div>

<style>
  .bg {
    position: fixed;
    inset: 0;
    z-index: -1;
    background:
      radial-gradient(ellipse 80% 60% at 50% 0%, #0c1232 0%, transparent 60%),
      linear-gradient(180deg, #060818 0%, #04061a 100%);
  }
</style>
