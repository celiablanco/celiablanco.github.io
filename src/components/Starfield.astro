---
// Subtle CSS-only starfield. Three layers of varying size/depth, slow twinkle.
---
<div class="starfield" aria-hidden="true">
  <div class="stars stars--small"></div>
  <div class="stars stars--medium"></div>
  <div class="stars stars--large"></div>
  <div class="nebula"></div>
</div>

<style>
  .starfield {
    position: fixed;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    background: linear-gradient(180deg, #060818 0%, #03050f 100%);
  }

  .nebula {
    display: none;
  }

  @keyframes nebula-drift {
    from { transform: translate(0, 0) scale(1); }
    to { transform: translate(-3%, 2%) scale(1.05); }
  }

  .stars {
    position: absolute;
    inset: 0;
    background-repeat: repeat;
    will-change: transform, opacity;
  }

  /* Small distant stars — densest layer */
  .stars--small {
    background-image:
      radial-gradient(1px 1px at 25% 12%, rgba(255, 248, 220, 0.85), transparent 50%),
      radial-gradient(1px 1px at 60% 28%, rgba(255, 248, 220, 0.75), transparent 50%),
      radial-gradient(1px 1px at 88% 8%, rgba(255, 248, 220, 0.9), transparent 50%),
      radial-gradient(1px 1px at 12% 45%, rgba(255, 248, 220, 0.65), transparent 50%),
      radial-gradient(1px 1px at 73% 53%, rgba(255, 248, 220, 0.85), transparent 50%),
      radial-gradient(1px 1px at 45% 68%, rgba(255, 248, 220, 0.7), transparent 50%),
      radial-gradient(1px 1px at 92% 81%, rgba(255, 248, 220, 0.8), transparent 50%),
      radial-gradient(1px 1px at 18% 91%, rgba(255, 248, 220, 0.75), transparent 50%),
      radial-gradient(1px 1px at 38% 19%, rgba(255, 248, 220, 0.6), transparent 50%),
      radial-gradient(1px 1px at 67% 76%, rgba(255, 248, 220, 0.85), transparent 50%),
      radial-gradient(1px 1px at 6% 31%, rgba(255, 248, 220, 0.7), transparent 50%),
      radial-gradient(1px 1px at 51% 41%, rgba(255, 248, 220, 0.55), transparent 50%);
    background-size: 600px 600px;
  }

  /* Medium stars */
  .stars--medium {
    background-image:
      radial-gradient(1.5px 1.5px at 30% 22%, rgba(255, 245, 210, 0.95), transparent 50%),
      radial-gradient(1.5px 1.5px at 78% 64%, rgba(255, 245, 210, 0.9), transparent 50%),
      radial-gradient(1.5px 1.5px at 14% 78%, rgba(255, 245, 210, 0.85), transparent 50%),
      radial-gradient(1.5px 1.5px at 56% 14%, rgba(255, 245, 210, 0.95), transparent 50%),
      radial-gradient(1.5px 1.5px at 91% 36%, rgba(255, 245, 210, 0.8), transparent 50%);
    background-size: 800px 800px;
  }

  /* Large bright stars — sparse */
  .stars--large {
    background-image:
      radial-gradient(2px 2px at 22% 38%, rgba(255, 245, 220, 0.85), transparent 50%),
      radial-gradient(2px 2px at 80% 18%, rgba(255, 245, 220, 0.95), transparent 50%),
      radial-gradient(2px 2px at 47% 82%, rgba(255, 245, 220, 0.8), transparent 50%);
    background-size: 1100px 1100px;
  }

  @keyframes twinkle-slow {
    0%, 100% { opacity: 0.7; }
    50% { opacity: 1; }
  }

  @keyframes twinkle-medium {
    0%, 100% { opacity: 0.85; }
    50% { opacity: 1; }
  }

  @keyframes twinkle-fast {
    0%, 100% { opacity: 0.75; }
    25% { opacity: 1; }
    50% { opacity: 0.85; }
    75% { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .stars, .nebula { animation: none; }
  }
</style>
