---
const { pathname } = Astro.url;

const isSpanish = pathname === '/es' || pathname === '/es/' || pathname.startsWith('/es/');
const lang: 'en' | 'es' = isSpanish ? 'es' : 'en';

const isActive = (href: string) => {
  // Normalize trailing slashes for both sides.
  const norm = (s: string) => (s.length > 1 ? s.replace(/\/$/, '') : s);
  const a = norm(pathname);
  const b = norm(href);
  if (b === '/' || b === '/es') {
    return a === b || a === b + '/index' || a === b + '/index.html';
  }
  return a === b || a.startsWith(b + '/');
};

const navItemsByLang = {
  en: [
    { label: 'Home', href: '/' },
    { label: 'Research', href: '/research' },
    { label: 'Publications', href: '/publications' },
    { label: 'Contact', href: '/contact' },
  ],
  es: [
    { label: 'Inicio', href: '/es' },
    { label: 'Investigación', href: '/es/research' },
    { label: 'Publicaciones', href: '/es/publications' },
    { label: 'Contacto', href: '/es/contact' },
  ],
};

const navItems = navItemsByLang[lang];

// Map current path to its counterpart in the other language.
function mirrorPath(p: string): string {
  const trimmed = p.replace(/\/$/, '');
  if (lang === 'es') {
    // /es -> /
    if (trimmed === '/es' || trimmed === '') return '/';
    // /es/foo -> /foo
    if (trimmed.startsWith('/es/')) return trimmed.slice(3) || '/';
    return '/';
  }
  // EN -> ES
  if (trimmed === '' || trimmed === '/') return '/es';
  return '/es' + trimmed;
}

const otherLangHref = mirrorPath(pathname);
const otherLang: 'en' | 'es' = lang === 'es' ? 'en' : 'es';
const toggleAria =
  lang === 'es' ? 'Switch to English' : 'Cambiar a español';
const navAriaLabel = lang === 'es' ? 'Principal' : 'Primary';
const navToggleAria =
  lang === 'es' ? 'Mostrar navegación' : 'Toggle navigation';
---
<header class="site-header">
  <div class="container header-inner">
    <a href={lang === 'es' ? '/es' : '/'} class="brand">
      <span class="brand-name">Celia Blanco</span>
    </a>
    <button class="nav-toggle" aria-label={navToggleAria} aria-expanded="false" aria-controls="primary-nav">
      <span></span><span></span><span></span>
    </button>
    <nav id="primary-nav" class="primary-nav" aria-label={navAriaLabel}>
      <ul>
        {navItems.map(({ label, href }) => (
          <li>
            <a href={href} class:list={["nav-link", { active: isActive(href) }]}>{label}</a>
          </li>
        ))}
        <li class="lang-item">
          <a
            href={otherLangHref}
            class="lang-toggle"
            aria-label={toggleAria}
            hreflang={otherLang}
            title={toggleAria}
          >
            {otherLang === 'es' ? (
              <svg class="flag" viewBox="0 0 6 4" aria-hidden="true" focusable="false">
                <rect width="6" height="4" fill="#AA151B" />
                <rect y="1" width="6" height="2" fill="#F1BF00" />
              </svg>
            ) : (
              <svg class="flag" viewBox="0 0 60 30" aria-hidden="true" focusable="false">
                <clipPath id="uk-clip">
                  <path d="M30,15 h30 v15 z v-15 h-30 z h-30 v-15 z v15 h30 z" />
                </clipPath>
                <path d="M0,0 v30 h60 v-30 z" fill="#012169" />
                <path d="M0,0 L60,30 M60,0 L0,30" stroke="#fff" stroke-width="6" />
                <path d="M0,0 L60,30 M60,0 L0,30" clip-path="url(#uk-clip)" stroke="#C8102E" stroke-width="4" />
                <path d="M30,0 v30 M0,15 h60" stroke="#fff" stroke-width="10" />
                <path d="M30,0 v30 M0,15 h60" stroke="#C8102E" stroke-width="6" />
              </svg>
            )}
            <span class="visually-hidden">{toggleAria}</span>
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    background: rgba(6, 8, 24, 0.75);
    border-bottom: 1px solid var(--color-border-subtle);
    transition: background 0.3s var(--ease);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 76px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    color: var(--color-text);
    text-decoration: none;
    font-family: var(--font-sans);
  }

  .brand:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  .brand-name {
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: 0.01em;
  }

  .primary-nav ul {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    position: relative;
    display: inline-block;
    padding: 0.5rem 0;
    font-family: var(--font-sans);
    font-size: 0.92rem;
    font-weight: 400;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s var(--ease);
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--color-text);
    text-decoration: none;
  }

  .nav-link.active {
    font-weight: 500;
  }

  .lang-item {
    margin-left: 0.25rem;
    padding-left: var(--space-2);
    border-left: 1px solid var(--color-border-subtle);
  }

  .lang-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.3rem 0.4rem;
    line-height: 0;
    text-decoration: none;
    border: 1px solid var(--color-border-subtle);
    border-radius: 4px;
    background: transparent;
    transition: border-color 0.2s var(--ease), background 0.2s var(--ease), transform 0.2s var(--ease);
  }

  .lang-toggle:hover,
  .lang-toggle:focus-visible {
    border-color: var(--color-gold);
    background: var(--color-gold-soft);
    text-decoration: none;
  }

  .flag {
    display: block;
    height: 14px;
    width: auto;
    border-radius: 1px;
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.08);
    transition: filter 0.2s var(--ease);
  }

  .lang-toggle:hover .flag,
  .lang-toggle:focus-visible .flag {
    filter: brightness(1.05);
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    padding: 8px;
    background: transparent;
    border: 1px solid var(--color-border-subtle);
    border-radius: 4px;
    cursor: pointer;
  }

  .nav-toggle span {
    display: block;
    width: 18px;
    height: 1px;
    background: var(--color-text);
    transition: all 0.3s var(--ease);
  }

  .nav-toggle[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  .nav-toggle[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
  }
  .nav-toggle[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  @media (max-width: 768px) {
    .nav-toggle { display: flex; }

    .primary-nav {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: rgba(6, 8, 24, 0.96);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      border-bottom: 1px solid var(--color-border-subtle);
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.4s var(--ease);
    }

    .primary-nav.open {
      max-height: 400px;
    }

    .primary-nav ul {
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      padding: var(--space-2) var(--space-4);
    }

    .primary-nav li {
      border-top: 1px solid var(--color-border-subtle);
    }

    .primary-nav li:first-child { border-top: none; }

    .nav-link {
      display: block;
      padding: 1rem 0;
    }

    .lang-item {
      margin-left: 0;
      padding-left: 0;
      border-left: none;
      padding: 0.85rem 0;
    }

    .lang-toggle {
      display: inline-flex;
      width: auto;
    }

    .brand-name {
      font-size: 0.95rem;
    }
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
  const nav = document.querySelector<HTMLElement>('.primary-nav');
  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!open));
    nav?.classList.toggle('open', !open);
  });
</script>
